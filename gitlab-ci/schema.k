    StepNamedValues
    """

    [key: str]: str | float | bool | [any] | any

    check:
        regex.match(key, r"^[a-zA-Z_][a-zA-Z0-9_]*$")

schema StepOciReference:
    r"""
    OCIReference is a reference to a function hosted in an OCI repository.

    Attributes
    ----------
    oci : JobRunItems1V0FuncV2Oci, required
    """

    oci: JobRunItems1V0FuncV2Oci

schema WorkflowAutoCancel:
    r"""
    Define the rules for when pipeline should be automatically cancelled.

    Attributes
    ----------
    on_job_failure : "none" | "all", optional, default is "none"
    on_new_commit : "conservative" | "interruptible" | "none", optional
    """

    on_job_failure?: "none" | "all"
    on_new_commit?: "conservative" | "interruptible" | "none"

