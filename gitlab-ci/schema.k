    gitlab_secrets_manager : JobSecretsGitlabSecretsManager, optional
    file : bool, optional, default is True
    token : str, optional
        Specifies the JWT variable that should be used to authenticate with the secret provider.
    """

    vault?: any
    gcp_secret_manager?: JobSecretsGcpSecretManager
    azure_key_vault?: JobSecretsAzureKeyVault
