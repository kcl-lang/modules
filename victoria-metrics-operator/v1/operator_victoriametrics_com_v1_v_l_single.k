    mountPropagation : str, default is Undefined, optional
        mount propagation
    name : str, default is Undefined, required
        name
    readOnly : bool, default is Undefined, optional
        read only
    recursiveReadOnly : str, default is Undefined, optional
        recursive read only
    subPath : str, default is Undefined, optional
        sub path
    subPathExpr : str, default is Undefined, optional
        sub path expr
    """


    mountPath: str

    mountPropagation?: str

    name: str

    readOnly?: bool

    recursiveReadOnly?: str

    subPath?: str

    subPathExpr?: str


schema OperatorVictoriametricsComV1VLSingleStatus:
    r"""
    operator victoriametrics com v1 v l single status

    Attributes
    ----------
    conditions : [OperatorVictoriametricsComV1VLSingleStatusConditionsItems0], default is Undefined, optional
        conditions
    observedGeneration : int, default is Undefined, optional
        observed generation
    reason : str, default is Undefined, optional
        reason
    updateStatus : str, default is Undefined, optional
        update status
    """


    conditions?: [OperatorVictoriametricsComV1VLSingleStatusConditionsItems0]

    observedGeneration?: int

    reason?: str

    updateStatus?: str


schema OperatorVictoriametricsComV1VLSingleStatusConditionsItems0:
    r"""
    operator victoriametrics com v1 v l single status conditions items0

    Attributes
    ----------
    lastTransitionTime : str, default is Undefined, required
        last transition time
    lastUpdateTime : str, default is Undefined, required
        last update time
    message : str, default is Undefined, optional
        message
    observedGeneration : int, default is Undefined, optional
        observed generation
    reason : str, default is Undefined, required
        reason
    status : str, default is Undefined, required
        status
    $type : str, default is Undefined, required
        type
    """


    lastTransitionTime: str

    lastUpdateTime: str

    message?: str

    observedGeneration?: int

    reason: str

    status: "True" | "False" | "Unknown"

    $type: str


    check:
        len(message) <= 32768 if message
        observedGeneration >= 0 if observedGeneration not in [None, Undefined]
        len(reason) <= 1024
        len(reason) >= 1
        len($type) <= 316


