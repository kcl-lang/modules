    operator victoriametrics com v1 v l single spec tolerations items0

    Attributes
    ----------
    effect : str, default is Undefined, optional
        effect
    key : str, default is Undefined, optional
        key
    operator : str, default is Undefined, optional
        operator
    tolerationSeconds : int, default is Undefined, optional
        toleration seconds
    value : str, default is Undefined, optional
        value
    """


    effect?: str

    key?: str

    operator?: str

    tolerationSeconds?: int

    value?: str


schema OperatorVictoriametricsComV1VLSingleSpecVolumeMountsItems0:
    r"""
    operator victoriametrics com v1 v l single spec volume mounts items0

    Attributes
    ----------
    mountPath : str, default is Undefined, required
